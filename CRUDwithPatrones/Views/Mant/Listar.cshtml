@model IEnumerable<PeliculasModel>

@{
    ViewData["Title"] = "Listado de Películas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card">
    <div class="card-header">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Listado de Películas</h5>
            <a asp-action="Guardar" class="btn btn-success btn-sm">Agregar Nueva</a>
        </div>
    </div>
    <div class="card-body">
        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Sinopsis</th>
                    <th>Lanzamiento</th>
                    <th style="width: 200px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.IdPelicula</td>
                        <td>@item.NombrePelicula</td>
                        <td>@item.Sinopsis</td>
                        <td>@item.FechaLanzamiento.ToString("dd/MM/yyyy")</td>
                        <td>
                            <a asp-action="Editar" asp-route-idPelicula="@item.IdPelicula" class="btn btn-primary btn-sm">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                            <a asp-action="Eliminar" asp-route-idPelicula="@item.IdPelicula" class="btn btn-danger btn-sm"
                               onclick="return confirm('¿Estás seguro de eliminar esta película?')">
                                <i class="bi bi-trash"></i> Eliminar
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
